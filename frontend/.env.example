# AlbNet Frontend – variabla mjedisi
# Kopjoni: cp .env.example .env.local

# URL e backend-it (duhet të përputhet me PORT te backend/.env)
# Nëse backend nis në portin 5000: http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# OAuth – Google (i njëjti Client ID si GOOGLE_CLIENT_ID te backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OAuth – Apple (i njëjti Services ID si APPLE_CLIENT_ID te backend)
NEXT_PUBLIC_APPLE_CLIENT_ID=com.albnet.app.web
