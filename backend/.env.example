# AlbNet Backend – variabla mjedisi
# Kopjoni: cp .env.example .env dhe plotësoni vlerat

# Server (porti duhet të përputhet me NEXT_PUBLIC_API_URL te frontend)
PORT=5000
NODE_ENV=development

# MongoDB (MongoDB Atlas ose lokal)
MONGODB_URI=mongodb://localhost:27017/albnet

# JWT
JWT_SECRET=ndryshojeni_me_nje_ce_te_forte_sekrete
JWT_EXPIRE=7d

# Frontend URL (për CORS – ku nisni Next.js)
FRONTEND_URL=http://localhost:3000

# OAuth – Google (https://console.cloud.google.com/apis/credentials)
# Krijo OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:3000, https://albneti.vercel.app
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OAuth – Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
# Krijo Services ID për "Sign in with Apple"
# Domains: albneti.vercel.app | Return URL: https://albneti.vercel.app
APPLE_CLIENT_ID=com.albnet.app.web

# Cloudinary (për foto/video) – obligativ për upload avatar/post/story
CLOUDINARY_CLOUD_NAME=emri_juaj_cloudinary
CLOUDINARY_API_KEY=api_key_juaj
CLOUDINARY_API_SECRET=api_secret_juaj

# Muzikë – Jamendo API (opsional, këngë të plota royalty-free)
# Regjistrohu falas: https://devportal.jamendo.com → krijo app → kopjo Client ID
# Pa këtë, përdoret iTunes Search (preview 30s, këngë reale shqiptare) + biblioteka lokale
JAMENDO_CLIENT_ID=your-jamendo-client-id

# Email (opsional – verifikim & reset fjalëkalimi)
# Për Gmail: SMTP_HOST=smtp.gmail.com, SMTP_USER=emaili_juaj@gmail.com,
# SMTP_PASS=fjalëkalimi i aplikacionit nga https://myaccount.google.com/apppasswords
# Mos përdorni smtp.example.com – nuk ekziston.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=emaili_juaj@gmail.com
SMTP_PASS=fjalekalimi_aplikacionit
SMTP_FROM=AlbNet <emaili_juaj@gmail.com>

# Stripe (verifikim / abonim) – https://dashboard.stripe.com/test/apikeys
# Test: sk_test_... dhe pk_test_... | Webhook: stripe listen --forward-to localhost:5000/api/verification/stripe-webhook
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Metered.ca TURN – thirrje audio/video (https://dashboard.metered.ca)
# Krijo credential → Instructions → kopjo App Name + API Key
# Udhëzime të plota: METERED-SETUP.md në rrënjë të projektit
METERED_APP_NAME=albneti
METERED_TURN_API_KEY=your-metered-credential-api-key
METERED_TURN_REGION=global

# Web Push – njoftime jashtë app-it (thirrje, mesazhe, pëlqime)
# Gjenero: cd backend && node scripts/generate-vapid.js
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@albneti.vercel.app
