{
  "name": "albnet-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "mobile": "cd mobile && npm start",
    "mobile:android": "cd mobile && npm run android",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:build": "cd mobile && npx eas build --platform all",
    "desktop": "cd desktop && npm start",
    "desktop:build": "cd desktop && npm run build"
  }
}
