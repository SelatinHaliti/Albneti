# AlbNet Frontend – variabla mjedisi
# Kopjoni: cp .env.example .env.local

# URL e backend-it (duhet të përputhet me PORT te backend/.env)
# Lokal: http://localhost:5000 | Prod: https://albneti-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Opsionale në Vercel (server-side proxy) – e njëjta URL si backend prod
# BACKEND_API_URL=https://albneti-api.onrender.com

# OAuth – Google (i njëjti Client ID si GOOGLE_CLIENT_ID te backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OAuth – Apple (i njëjti Services ID si APPLE_CLIENT_ID te backend)
NEXT_PUBLIC_APPLE_CLIENT_ID=com.albnet.app.web

# Stripe (opsional – publikohet vetëm publishable key)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
